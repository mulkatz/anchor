rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check userId ownership
    function isOwner(userId) {
      return (request.auth != null && request.auth.uid == userId) ||
             (userId.matches('anonymous_.*') && request.auth == null);
    }

    // Users collection
    match /users/{userId} {

      // Conversations subcollection
      match /conversations/{conversationId} {
        // Read: User can read their own conversations
        allow read: if isOwner(userId);

        // Create: Only if creating conversation for self
        allow create: if isOwner(userId) &&
                         request.resource.data.userId == userId;

        // Update: Owner can archive/unarchive
        allow update: if isOwner(userId) &&
                         request.resource.data.userId == userId;

        // Delete: Owner can delete archived conversations only
        allow delete: if isOwner(userId) &&
                         resource.data.status == 'archived';

        // Messages subcollection within conversations
        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }

      // Legacy: Chat messages - users can read/write their own messages
      // Keep for migration period
      match /messages/{messageId} {
        allow read, write: if isOwner(userId);
      }

      // User profiles
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Profile subcollection (user settings, display name, etc.)
      match /profile/{profileId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Daily logs (Tide Log journaling feature)
      match /daily_logs/{logId} {
        allow read: if request.auth != null && request.auth.uid == userId;

        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.userId == userId
                      && request.resource.data.mood_depth >= 0
                      && request.resource.data.mood_depth <= 100
                      && request.resource.data.note_text.size() <= 1000
                      && request.resource.data.weather in ['stormy', 'foggy', 'clear', 'sunny', 'turbulent'];

        allow update: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.mood_depth >= 0
                      && request.resource.data.mood_depth <= 100
                      && request.resource.data.note_text.size() <= 1000;

        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Feedback collection - write-only for users
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text.size() <= 1000;
      allow read, update, delete: if false; // Admin only
    }

    // Default: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
