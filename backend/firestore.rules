rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Chat messages - users can read/write their own messages
    match /users/{userId}/messages/{messageId} {
      // Authenticated users can access their own messages
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Anonymous users (development/testing)
      // Pattern: anonymous_[uuid]
      allow read, write: if userId.matches('anonymous_.*');
    }

    // Future: User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
