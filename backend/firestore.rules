rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check userId ownership
    function isOwner(userId) {
      return (request.auth != null && request.auth.uid == userId) ||
             (userId.matches('anonymous_.*') && request.auth == null);
    }

    // Users collection
    match /users/{userId} {

      // Conversations subcollection
      match /conversations/{conversationId} {
        // Read: User can read their own conversations
        allow read: if isOwner(userId);

        // Create: Only if creating conversation for self
        allow create: if isOwner(userId) &&
                         request.resource.data.userId == userId;

        // Update: Owner can archive/unarchive
        allow update: if isOwner(userId) &&
                         request.resource.data.userId == userId;

        // Delete: Owner can delete archived conversations only
        allow delete: if isOwner(userId) &&
                         resource.data.status == 'archived';

        // Messages subcollection within conversations
        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }

      // Legacy: Chat messages - users can read/write their own messages
      // Keep for migration period
      match /messages/{messageId} {
        allow read, write: if isOwner(userId);
      }

      // User profiles
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Profile subcollection (user settings, display name, etc.)
      match /profile/{profileId} {
        // Special handling for psychologicalProfile - read only for users
        allow read: if request.auth != null && request.auth.uid == userId;

        // psychologicalProfile can only be written by backend functions
        allow write: if request.auth != null
                     && request.auth.uid == userId
                     && profileId != 'psychologicalProfile';

        // Archived notes subcollection for psychological profile
        match /archivedNotes/{noteId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          // Only backend functions can write
          allow write: if false;
        }
      }

      // Daily logs (Tide Log journaling feature)
      match /daily_logs/{logId} {
        allow read: if request.auth != null && request.auth.uid == userId;

        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.userId == userId
                      && request.resource.data.mood_depth >= 0
                      && request.resource.data.mood_depth <= 100
                      && request.resource.data.note_text.size() <= 1000
                      && request.resource.data.weather in ['stormy', 'foggy', 'clear', 'sunny', 'turbulent'];

        allow update: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.mood_depth >= 0
                      && request.resource.data.mood_depth <= 100
                      && request.resource.data.note_text.size() <= 1000;

        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Journal entries (Depths free-form journaling)
      match /journal_entries/{entryId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && request.resource.data.userId == userId
                      && request.resource.data.date is string
                      && request.resource.data.sessions is list;

        allow update: if isOwner(userId)
                      && request.resource.data.userId == userId;

        // No delete allowed - therapeutic permanence
        allow delete: if false;
      }

      // Illuminate entries (CBT thought records - Lighthouse feature)
      match /illuminate_entries/{entryId} {
        allow read: if isOwner(userId);

        // Create: accept emotionalIntensity (new) or anxietyIntensity (legacy)
        allow create: if isOwner(userId)
                      && request.resource.data.userId == userId
                      && request.resource.data.situation is string
                      && request.resource.data.automaticThoughts is string
                      && (
                        (request.resource.data.emotionalIntensity >= 0
                         && request.resource.data.emotionalIntensity <= 100)
                        ||
                        (request.resource.data.anxietyIntensity >= 0
                         && request.resource.data.anxietyIntensity <= 100)
                      );

        // Update: accept either field name
        allow update: if isOwner(userId)
                      && request.resource.data.userId == userId;

        // Allow deletion for data management
        allow delete: if isOwner(userId);
      }

      // Anxiety assessments (optional periodic check-ins)
      match /anxiety_assessments/{assessmentId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && request.resource.data.userId == userId
                      && request.resource.data.responses is list
                      && request.resource.data.totalScore >= 0
                      && request.resource.data.totalScore <= 21;

        // Assessments are immutable once created
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      // Weekly insights (AI-generated)
      match /weekly_insights/{insightId} {
        allow read: if isOwner(userId);

        // Insights are created by backend functions only
        allow create: if false;

        // Users can mark as viewed and rate helpfulness
        allow update: if isOwner(userId)
                      && request.resource.data.viewed is bool
                      && (request.resource.data.helpfulnessRating == null
                          || (request.resource.data.helpfulnessRating >= 1
                              && request.resource.data.helpfulnessRating <= 5));

        allow delete: if isOwner(userId);
      }

      // The Dive - Progress tracking
      match /dive_progress/{progressId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && request.resource.data.userId == userId;

        allow update: if isOwner(userId)
                      && request.resource.data.userId == userId;

        // Allow deletion for data management
        allow delete: if isOwner(userId);
      }

      // The Dive - Sessions (lesson conversations)
      match /dive_sessions/{sessionId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && request.resource.data.userId == userId
                      && request.resource.data.lessonId is string;

        allow update: if isOwner(userId)
                      && request.resource.data.userId == userId;

        allow delete: if isOwner(userId);

        // Messages within dive sessions
        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // Feedback collection - write-only for users
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text.size() <= 1000;
      allow read, update, delete: if false; // Admin only
    }

    // Default: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
